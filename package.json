{
	"name": "obsidian-manager",
	"version": "0.3.7",
	"description": "Unified task and time management for Obsidian.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"license": "MIT",
	"devDependencies": {
		"@codemirror/language": "^6.0.0",
		"@codemirror/state": "^6.0.0",
		"@codemirror/view": "^6.0.0",
		"@eslint/js": "9.30.1",
		"@types/node": "^16.11.6",
		"esbuild": "0.25.5",
		"esbuild-svelte": "^0.9.3",
		"eslint-plugin-obsidianmd": "0.4.1",
		"globals": "14.0.0",
		"jiti": "2.6.1",
		"jsdom": "^29.1.1",
		"svelte": "^4.2.19",
		"svelte-check": "^3.8.0",
		"svelte-preprocess": "^5.1.4",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1",
		"vitest": "^4.1.10"
	},
	"dependencies": {
		"chrono-node": "^2.9.1",
		"ical.js": "^2.2.1",
		"monkey-around": "^2.3.0",
		"obsidian": "^1.13.0",
		"svelte-inview": "^4.0.2"
	}
}
